{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "postPrebuildCommand": "node -e \"const fs=require('fs'); fs.mkdirSync('android/app/libs',{recursive:true}); fs.copyFileSync('sdk-files/android/KobitonBiometric.aar','android/app/libs/KobitonBiometric.aar');\"",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "simulator": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
