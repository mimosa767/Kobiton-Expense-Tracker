{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "cache": {
        "disabled": true
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false,
        "cache": {
          "disabled": true
        }
      }
    },
    "simulator": {
      "distribution": "internal",
      "cache": {
        "disabled": true
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true,
        "cache": {
          "disabled": true
        }
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
