{
  "expo": {
    "name": "Kobiton Expense Tracker",
    "slug": "kobiton-expense-tracker",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "kobiton-expense-tracker",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F2D8A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kobiton.expensetracker",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Kobiton Expense Tracker to capture receipt photos.",
        "NSPhotoLibraryUsageDescription": "Allow Kobiton Expense Tracker to select receipt images from your library.",
        "NSFaceIDUsageDescription": "Allow Face ID to quickly sign in to Kobiton Expense Tracker."
      }
    },
    "android": {
      "package": "com.kobiton.expensetracker",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-image-picker",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Kobiton Expense Tracker to capture receipt photos."
        }
      ],
      [
        "./plugins/withKobitonSDK",
        {
          "apiKey": "",
          "baseUrl": "https://api.kobiton.com",
          "enableNetworkCapture": true,
          "enableCrashReporting": true,
          "biometricSupport": true,
          "imageInjectionSupport": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "autolinking": {
      "exclude": ["@react-native-community/slider"]
    }
  }
}
