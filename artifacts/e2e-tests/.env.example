# Copy to .env and fill in your Kobiton API key, then run with --env-file=.env
# Find/rotate the key at https://portal.kobiton.com → Settings → API key.

KOBITON_USERNAME=mimosa767
KOBITON_API_KEY=

# --- Optional overrides ---
# Target a different device / OS version:
# KOBITON_DEVICE_NAME=iPhone 11 Pro
# KOBITON_PLATFORM_VERSION=16.1
# KOBITON_DEVICE_GROUP=KOBITON
# Point at a specific app build instead of the latest iOS version:
# KOBITON_APP=kobiton-store:690060

# Override the login credentials used by the test:
# LOGIN_EMAIL=test@kobiton.com
# LOGIN_PASSWORD=kobiton123
